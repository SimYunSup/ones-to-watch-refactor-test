---
// munja search island — dictionary-free CJK/Latin full-text search running
// entirely in the browser against the prebuilt /index.bin (written by the
// notion-loader at build time). No framework, no backend.
//
// Each result links to the post with `?q=<query>` so the destination page can
// natively highlight the matched terms (see news/post/[slug].astro).
---

<div class="munja-search" data-munja>
  <div class="munja-field">
    <svg
      class="munja-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      class="munja-input"
      type="search"
      placeholder="뉴스레터 검색…"
      aria-label="뉴스레터 검색"
      autocomplete="off"
      spellcheck="false"
    />
  </div>
  <ul class="munja-panel" role="listbox" aria-label="검색 결과" hidden></ul>
</div>

<script>
  import init, { search_json } from "@pickhealer/munja";
  import wasmUrl from "@pickhealer/munja/munja_bg.wasm?url";

  type Hit = { title: string; href: string; category: string; body: string };

  const escapeHtml = (s: string) =>
    s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!
    );
  const escapeRe = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

  // Build a ~80-char snippet centered on the first matched term, with every
  // term wrapped in <mark> — this is what makes it obvious *why* a doc matched
  // (e.g. an English word buried in Korean body text).
  function snippet(body: string, terms: string[]): string {
    const lower = body.toLowerCase();
    let pos = -1;
    for (const t of terms) {
      const i = lower.indexOf(t);
      if (i !== -1 && (pos === -1 || i < pos)) pos = i;
    }
    const start = pos === -1 ? 0 : Math.max(0, pos - 30);
    const end = pos === -1 ? 90 : Math.min(body.length, pos + 50);
    let html = escapeHtml(body.slice(start, end));
    for (const t of terms) {
      if (t) html = html.replace(new RegExp(`(${escapeRe(t)})`, "gi"), "<mark>$1</mark>");
    }
    return (start > 0 ? "…" : "") + html + (end < body.length ? "…" : "");
  }

  document.querySelectorAll<HTMLElement>("[data-munja]").forEach((root) => {
    const input = root.querySelector<HTMLInputElement>(".munja-input");
    const panel = root.querySelector<HTMLUListElement>(".munja-panel");
    if (!input || !panel) return;

    let index: Uint8Array | null = null;
    const ready = (async () => {
      await init(wasmUrl);
      const res = await fetch(`${import.meta.env.BASE_URL.replace(/\/$/, "")}/index.bin`);
      if (!res.ok) throw new Error(`index.bin ${res.status}`);
      index = new Uint8Array(await res.arrayBuffer());
    })().catch((e) => console.error("munja: failed to load index", e));

    const close = () => {
      panel.hidden = true;
      panel.innerHTML = "";
    };

    const run = async () => {
      await ready;
      const raw = input.value.trim();
      if (!index || raw === "") return close();
      const terms = raw.toLowerCase().split(/\s+/).filter(Boolean);
      let hits: Hit[] = [];
      try {
        hits = JSON.parse(search_json(index, raw, 8)) as Hit[];
      } catch (e) {
        console.error("munja: search failed", e);
      }
      if (hits.length === 0) {
        panel.innerHTML = `<li class="munja-empty">검색 결과가 없어요</li>`;
        panel.hidden = false;
        return;
      }
      const qs = `?q=${encodeURIComponent(raw)}`;
      panel.innerHTML = hits
        .map(
          (h) => `<li role="option">
            <a href="${import.meta.env.BASE_URL.replace(/\/$/, "")}/${escapeHtml(h.href).replace(/^\//, "")}${qs}">
              <span class="munja-hit-head">
                <span class="munja-hit-title">${escapeHtml(h.title)}</span>
                <span class="munja-hit-cat">${escapeHtml(h.category)}</span>
              </span>
              <span class="munja-hit-snippet">${snippet(h.body, terms)}</span>
            </a>
          </li>`
        )
        .join("");
      panel.hidden = false;
    };

    input.addEventListener("input", run);
    input.addEventListener("focus", () => {
      if (input.value.trim() !== "") run();
    });
    input.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        input.value = "";
        close();
      } else if (e.key === "Enter") {
        const first = panel.querySelector<HTMLAnchorElement>("a");
        if (first) {
          e.preventDefault();
          window.location.href = first.href;
        }
      }
    });
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });
  });
</script>

<!-- Global (not scoped): result items are injected via innerHTML at runtime and
     would not receive Astro's scope attribute, so scoped rules would not apply. -->
<style is:global>
  .munja-search {
    position: relative;
    width: 100%;
    margin: 0 auto;
  }

  .munja-field {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0 16px;
    height: 48px;
    background: var(--card, #fff);
    border: 1px solid var(--line, #e2e8f0);
    border-radius: 10px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .munja-field:focus-within {
    border-color: var(--accent, #4f46e5);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent, #4f46e5) 18%, transparent);
  }
  .munja-icon {
    flex: none;
    width: 1rem;
    height: 1rem;
    color: var(--muted, #64748b);
  }
  .munja-input {
    flex: 1;
    min-width: 0;
    height: 100%;
    border: 0;
    background: transparent;
    color: var(--ink, #0f172a);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 14px;
    outline: none;
  }
  .munja-input::placeholder {
    color: var(--muted-color, #94a3b8);
  }
  /* Kill the native search "×" so the field stays clean. */
  .munja-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .munja-panel {
    position: absolute;
    z-index: 50;
    top: calc(100% + 0.55rem);
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0;
    padding: 0.4rem;
    list-style: none;
    max-height: 24rem;
    overflow-y: auto;
    background: var(--card-bg, #fff);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: 1rem;
    box-shadow: var(--shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    text-align: left;
  }
  .munja-panel[hidden] {
    display: none;
  }
  .munja-panel li {
    margin: 0;
    list-style: none;
  }

  .munja-panel a {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.7rem;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.12s ease;
  }
  .munja-panel a:hover,
  .munja-panel a:focus-visible {
    background: var(--hover-bg, #f1f5f9);
    outline: none;
  }

  .munja-hit-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .munja-hit-title {
    flex: 1;
    min-width: 0;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.35;
    color: var(--foreground, #0f172a);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .munja-hit-cat {
    flex: none;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    color: var(--primary-color, #4f46e5);
    background: color-mix(in srgb, var(--primary-color, #4f46e5) 12%, transparent);
  }
  .munja-hit-snippet {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--muted-color, #64748b);
    word-break: break-word;
  }
  .munja-hit-snippet mark {
    background: color-mix(in srgb, var(--primary-color, #4f46e5) 20%, transparent);
    color: var(--foreground, #0f172a);
    border-radius: 3px;
    padding: 0 2px;
    font-weight: 700;
  }

  .munja-empty {
    padding: 1rem 0.75rem;
    font-size: 0.9rem;
    color: var(--muted-color, #64748b);
    text-align: center;
  }
</style>
