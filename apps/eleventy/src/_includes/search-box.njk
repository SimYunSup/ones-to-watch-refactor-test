{#- Munja search island markup, shared by the home and archive pages.
    Ported verbatim from the inline JSX in apps/kudzu/src/pages/index.tsx
    and apps/kudzu/src/pages/news/list/[page].tsx — kept as its own include
    so both pages stay in sync. The behavior lives in public/search.js
    (copied to the output root by eleventy.config.js's passthrough copy),
    loaded via the <script type="module"> tag each page adds itself. #}
<div class="munja-search" data-munja>
  <div class="munja-field">
    <svg
      class="munja-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      class="munja-input"
      type="search"
      placeholder="뉴스레터 검색…"
      aria-label="뉴스레터 검색"
      autocomplete="off"
      spellcheck="false"
    />
  </div>
  <ul class="munja-panel" role="listbox" aria-label="검색 결과" hidden></ul>
</div>
